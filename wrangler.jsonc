{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "makotow-blog-astro",
  "compatibility_date": "2026-07-05",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "blog.makotow.net",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
