---
import { PUBLIC_GA_MEASUREMENT_ID } from "astro:env/client";

const measurementId = PUBLIC_GA_MEASUREMENT_ID?.trim();

if (measurementId && !/^G-[A-Z0-9]+$/.test(measurementId)) {
  throw new Error(
    "PUBLIC_GA_MEASUREMENT_ID must be a GA4 measurement ID such as G-XXXXXXXXXX."
  );
}

const enabled = import.meta.env.PROD && Boolean(measurementId);
const initializationScript = `
  // Inline scripts can run again after an Astro client-side navigation.
  // Configure the Google tag only once and let GA4 Enhanced Measurement
  // observe History API changes for subsequent page views.
  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function () {
    window.dataLayer.push(arguments);
  };

  if (!window.__ga4Initialized) {
    window.__ga4Initialized = true;
    window.gtag("js", new Date());
    window.gtag("config", ${JSON.stringify(measurementId)});
  }
`;
---

{
  enabled && (
    <>
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId!)}`}
      />
      <script is:inline set:html={initializationScript} />
    </>
  )
}
